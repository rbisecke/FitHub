root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_size = 4

[*.md]
# Trailing spaces are intentional line breaks in Markdown
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.toml]
indent_size = 2

[*.sql]
indent_size = 2

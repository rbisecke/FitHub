# Copy this to .env (gitignored) and fill in values.
# For local dev, run `supabase start` and copy the values from its output.

# ── Supabase (local dev) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<local-anon-key-from-supabase-start>

# ── FastAPI ───────────────────────────────────────────────────────────────────
# Backend only — never expose to the frontend.
# JWT verification uses JWKS (ES256), not a shared secret — see apps/api/CLAUDE.md.
SUPABASE_SERVICE_ROLE_KEY=<local-service-role-key-from-supabase-start>
SUPABASE_URL=http://localhost:54321

# ── Alembic (direct Postgres connection — backend only) ───────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── App ───────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000

# ── AI (Phase 5 only — leave blank until then) ────────────────────────────────
ANTHROPIC_API_KEY=
